    "@mantine/hooks": "^9.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@tabler/icons-react": "^3.0.0",
    "@tanstack/react-query": "^5.100.9",
    "ahooks": "^2.10.14",
    "chroma-js": "^3.0.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.0.0",
    "jszip": "^3.10.0",
    "katex": "^0.18.0",
    "lodash-es": "^4.17.21",
    "pdfjs-dist": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "react-syntax-highlighter": "^16.1.1",
    "react-transition-group": "^4.4.5",
    "rehype-katex": "^7.0.0",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "scripts": {
    "start-docker": "vite --no-open --host 0.0.0.0",
    "start": "yarn codegen && vite",
    "start-with-faro": "VITE_FARO_DISABLE=false vite",
    "build": "yarn codegen && tsc && vite build",
    "codegen": "orval",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "check-format": "prettier --list-different \"src/**/*.{js,jsx,ts,tsx,json,css}\"",
    "lint": "yarn run eslint \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/lodash-es": "^4.17.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-transition-group": "^4.4.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.38.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.0.0",
    "orval": "^8.9.1",
    "postcss": "^8.4.35",
    "postcss-preset-mantine": "^1.13.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "unified": "^11.0.5"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
